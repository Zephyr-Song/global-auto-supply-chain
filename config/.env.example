# 环境变量配置（复制为 .env 使用）
# LLM 配置
LLM_PROVIDER=openai          # openai / anthropic / local
LLM_MODEL=gpt-4              # 模型名称
OPENAI_API_KEY=sk-xxx        # OpenAI API Key
ANTHROPIC_API_KEY=sk-xxx     # Anthropic API Key

# 爬虫配置
APIFY_TOKEN=                  # Apify 平台 Token（可选）

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auto_supply_chain
DB_USER=postgres
DB_PASSWORD=

# 爬取配置
CRAWL_DELAY=2                 # 爬取间隔（秒）
CRAWL_MAX_PAGES=10            # 最大爬取页数
CRAWL_HEADLESS=true           # 无头模式
